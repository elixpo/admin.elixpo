# Elixpo Admin — environment template.
# Copy to .env.local and fill in. Encrypt with `./sops-reencrypt.sh` (-> .env).
# NEVER commit .env.local. The encrypted .env is safe to commit.

# --- Cloudflare API (used for discovery, metrics, and the local KV REST fallback) ---
CLOUDFLARE_ACCOUNT_ID=b3646c532659b14184b252f312f74ef3
CLOUDFLARE_API_TOKEN=              # scoped token (read; read-write in Phase 3)
CLOUDFLARE_KV_NAMESPACE_ID=        # admin-cache namespace id (local dev REST fallback only)

# --- Elixpo Accounts SSO (OAuth2 client for admin.elixpo) ---
ELIXPO_CLIENT_ID=                  # from accounts.elixpo OAuth app registration
ELIXPO_CLIENT_SECRET=              # shown once at registration
SESSION_SECRET=                    # long random string; signs the admin_session cookie

# --- Public (server-read at runtime; pushed as Pages vars by deploy.sh) ---
NEXT_PUBLIC_ACCOUNTS_URL=https://accounts.elixpo.com
NEXT_PUBLIC_APP_URL=https://admin.elixpo.com
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/api/auth/callback   # must match the OAuth app's registered redirect URI
